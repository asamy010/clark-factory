# ════════════════════════════════════════════════════════════════════════
# CLARK_DB — Environment variables
# ════════════════════════════════════════════════════════════════════════
# انسخ الملف ده لـ .env.local (محلي) وحط نفس القيم في Vercel project الجديد.
# ⚠️ ماتكوميتش .env.local أبداً.

# ─── Supabase (الكلاينت — مكشوفة للمتصفح، VITE_ prefix) ───────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ─── Supabase (السيرفر فقط — api/ + سكريبت الهجرة) ────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ─── للهجرة فقط: قراءة من Firestore الإنتاجي (READ-ONLY) ──────────────────
# نفس القيمة الموجودة في Vercel بتاع clark-factory الحالي.
# استخدمها على جهازك وقت تشغيل migrate، بعدين امسحها — متحطهاش في Vercel الجديد.
FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
