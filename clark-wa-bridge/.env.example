# CLARK WhatsApp Bridge — Environment variables
# Copy this file to .env and fill in the values.

# Your domain (DuckDNS subdomain)
DOMAIN=clark-rmg.duckdns.org

# Auth token — long random string. Generate with: openssl rand -hex 32
# CLARK uses this token to authenticate to the bridge.
# DO NOT commit this to git or share publicly.
AUTH_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Timezone for log timestamps and daily counter rollover
TZ=Africa/Cairo

# ── AI Agent incoming webhook (V1.2.0) ──
# When BOTH are set, incoming customer messages are forwarded (HMAC-signed)
# to CLARK's agent receiver. Leave BLANK to keep the bridge outgoing-only.
# WEBHOOK_URL = the Vercel receiver endpoint.
# WEBHOOK_SECRET = a long random string; MUST be identical to the WEBHOOK_SECRET
#   set in the Vercel project env. Generate with: openssl rand -hex 32
WEBHOOK_URL=https://clark-factory.vercel.app/api/ai-agent/incoming
WEBHOOK_SECRET=CHANGE_ME_SAME_AS_VERCEL
