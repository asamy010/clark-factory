rules_version = '2';

/* ═══════════════════════════════════════════════════════════════
   CLARK Factory — Firestore Security Rules (V19.64)
   ═══════════════════════════════════════════════════════════════
   نموذج الصلاحيات:
   - admin              : كل شيء (incl. role assignment, permissions edit)
   - manager            : كل شيء عدا تعديل users/permissions/customRoles/usersList
   - sales_accountant   : مبيعات + عملاء + قراءة عامة
   - purchase_accountant: مشتريات + موردين + خزنة + قراءة عامة
   - payroll_accountant : مرتبات + موظفين (بدون verify)
   - payroll_verifier   : verify المرتبات فقط (QR scan)
   - viewer             : قراءة محدودة (NOT financials/HR)

   الدور بيتقرا من factory/config — يدعم شكلين:
     cfg.users[uid] = "admin"        (نص)
     cfg.users[uid] = {role:"admin"} (object)

   ═══════════════════════════════════════════════════════════════
   V19.64 SECURITY HARDENING:
   1. factory/config: writes that touch users/permissions/customRoles/usersList → admin ONLY
      (was: any manager could self-promote to admin via DevTools — CRITICAL fix)
   2. Reads scoped by role: viewers/non-finance roles can no longer enumerate
      treasury / wsPayments / supplierPayments / purchase invoices / HR data /
      backups / fixed assets / accounting entries via direct SDK calls.
   3. payroll_verifier write removed from hrWeeksDocs — verify flow should go
      through narrower API endpoint (TODO V19.65). Keeps read for QR scan flow.
   4. auditDays writes restricted to manager+ — viewer can no longer poison the
      audit trail.
   5. migrationLog writes restricted to manager+ (was any authed).
   6. backups now admin-only (was manager+) — backup DUMPS contain sensitive HR
      data, so they need the same protection level as user-management.

   ═══════════════════════════════════════════════════════════════
   ⚠️ Bootstrap Admin (recovery escape hatch):
   The hardcoded UID below is a fallback if factory/config.users is corrupted.
   To rotate: (1) create a new admin account, (2) deploy rules with new UID,
   (3) revoke old UID's auth from Firebase Console.
   ═══════════════════════════════════════════════════════════════ */

service cloud.firestore {
  match /databases/{database}/documents {

    function isBootstrapAdmin() {
      return request.auth != null
          && request.auth.uid == 'fJDTS57ndvVfPozGgwYybKJymuA3';
    }

    function isAuthed() {
      return request.auth != null;
    }

    function getRole() {
      let cfg = get(/databases/$(database)/documents/factory/config).data;
      let u = cfg.get('users', {}).get(request.auth.uid, '');
      return u is string
        ? (u == '' ? 'viewer' : u)
        : u.get('role', 'viewer');
    }

    function hasRole(roles) {
      return isAuthed() && (isBootstrapAdmin() || getRole() in roles);
    }

    /* V21.9.32: DYNAMIC SCOPES — admin can edit role-to-scope mapping from
       the UI without re-deploying rules. Stored in factory/roleScopes:
       {
         isAdmin: ['admin'],
         isManagerPlus: ['admin','manager'],
         isSalesScope: ['admin','manager','sales_accountant'],
         isPurchaseScope: ['admin','manager','purchase_accountant','warehouse_keeper'],
         isHRRole: ['admin','manager','payroll_accountant','payroll_verifier'],
         isHRWriter: ['admin','manager','payroll_accountant'],
         isAnyAccountant: ['admin','manager','sales_accountant','purchase_accountant','payroll_accountant'],
         isAnyUser: [...all roles...]
       }
       Falls back to V21.9.26 hardcoded defaults if the doc doesn't exist. */
    function inScope(scopeName, fallbackRoles) {
      let scopesData = exists(/databases/$(database)/documents/factory/roleScopes)
        ? get(/databases/$(database)/documents/factory/roleScopes).data
        : null;
      let roles = scopesData != null
        ? scopesData.get(scopeName, fallbackRoles)
        : fallbackRoles;
      return isAuthed() && (isBootstrapAdmin() || getRole() in roles);
    }

    function isAdmin()        { return inScope('isAdmin', ['admin']); }
    function isManagerPlus()  { return inScope('isManagerPlus', ['admin', 'manager']); }
    function isSalesScope()   { return inScope('isSalesScope', ['admin','manager','sales_accountant']); }
    function isPurchaseScope(){ return inScope('isPurchaseScope', ['admin','manager','purchase_accountant','warehouse_keeper']); }
    function isWarehouseScope(){ return inScope('isWarehouseScope', ['admin','manager','purchase_accountant','warehouse_keeper']); }
    function isAnyAccountant(){ return inScope('isAnyAccountant', ['admin','manager','sales_accountant','purchase_accountant','payroll_accountant']); }
    function isHRRole()       { return inScope('isHRRole', ['admin','manager','payroll_accountant','payroll_verifier']); }
    function isHRWriter()     { return inScope('isHRWriter', ['admin','manager','payroll_accountant']); }
    function isAnyUser()      { return inScope('isAnyUser', ['admin','manager','sales_accountant','purchase_accountant','warehouse_keeper','payroll_accountant','payroll_verifier','viewer']); }

    /* V19.64: detect sensitive-field changes on factory/config.
       Only admin can change role assignments / permissions / custom roles. */
    function affectsSensitiveFields() {
      return resource != null
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['users','usersList','permissions','customRoles']);
    }

    /* ──────────────────────────────────────────────────────────
       V19.64 SPLIT: factory/config (sensitive — needs sub-field guard)
       vs factory/{others} (sales/tasks — manager+ writes any field)
       ────────────────────────────────────────────────────────── */
    match /factory/config {
      allow read:   if isAnyUser();
      /* CREATE: only admin (initial setup or rebuild) */
      allow create: if isAdmin();
      /* UPDATE: admin always; manager only if NOT touching sensitive fields */
      allow update: if isAdmin() || (isManagerPlus() && !affectsSensitiveFields());
      allow delete: if isAdmin();
    }

    /* V21.9.32: roleScopes doc — read by anyone (rules read it themselves),
       write by admin only. The rule function inScope() reads this doc on
       every request, so it must be readable by any authenticated user. */
    match /factory/roleScopes {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /factory/{docId} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }

    /* ──────────────────────────────────────────────────────────
       seasons/{season}/orders/{orderId}
       أوامر القص — نشاط تشغيلي
       ────────────────────────────────────────────────────────── */
    match /seasons/{season}/orders/{orderId} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }

    /* ──────────────────────────────────────────────────────────
       accountingDays/{YYYY-MM-DD}
       القيود اليومية المحاسبية — V19.64: read restricted to accountants
       (was isAnyUser — viewers shouldn't see ledger entries)
       ────────────────────────────────────────────────────────── */
    match /accountingDays/{day} {
      allow read:  if isAnyAccountant();
      allow write: if isAnyAccountant();
    }

    /* ──────────────────────────────────────────────────────────
       treasuryDays/{YYYY-MM-DD}
       حركات الخزنة اليومية — V19.64: read restricted to purchase scope+
       ────────────────────────────────────────────────────────── */
    match /treasuryDays/{day} {
      allow read:  if isPurchaseScope();
      allow write: if isPurchaseScope();
    }

    /* ──────────────────────────────────────────────────────────
       auditDays/{YYYY-MM-DD}
       سجل التدقيق — V19.64: write tightened to manager+ (was any authed)
       Viewer can no longer poison the audit trail.
       ────────────────────────────────────────────────────────── */
    match /auditDays/{day} {
      allow read:  if isManagerPlus();
      allow write: if isManagerPlus();
    }

    /* ──────────────────────────────────────────────────────────
       hrLogDays/{YYYY-MM-DD}
       سجل أنشطة المرتبات — V19.64: write reduced (verifier still reads for QR scan)
       ────────────────────────────────────────────────────────── */
    match /hrLogDays/{day} {
      allow read:  if isHRRole();
      allow write: if isHRRole();/* keep write for verifier audit-log entries */
    }

    /* ──────────────────────────────────────────────────────────
       hrWeeksDocs/{weekId}
       أسابيع المرتبات — V19.64: write restricted to HRWriter (no verifier)
       Verifier reads only for QR scan flow.
       TODO V19.65: route verifier writes through admin-SDK API endpoint.
       ────────────────────────────────────────────────────────── */
    match /hrWeeksDocs/{weekId} {
      allow read:  if isHRRole();
      allow write: if isHRWriter();
    }

    /* ──────────────────────────────────────────────────────────
       V19.57 — Master data byId (V19.64: HR scope tightened)
       ────────────────────────────────────────────────────────── */
    match /customersDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }
    match /suppliersDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isPurchaseScope();
    }
    match /workshopsDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }
    match /employeesDocs/{id} {
      /* V19.64: HR-only read — pay grades are confidential */
      allow read:  if isHRRole();
      allow write: if isHRWriter();
    }
    match /empDebtsDocs/{id} {
      allow read:  if isHRRole();
      allow write: if isHRWriter();
    }
    match /generalProductsDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isPurchaseScope();
    }
    match /fabricsDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }
    match /accessoriesDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }

    /* ──────────────────────────────────────────────────────────
       V19.49 — daily-split (V19.64: payment data read restricted)
       ────────────────────────────────────────────────────────── */
    match /custPaymentsDays/{day} {
      allow read:  if isAnyAccountant();
      allow write: if hasRole(['admin','manager','sales_accountant','purchase_accountant']);
    }

    match /supplierPaymentsDays/{day} {
      allow read:  if isPurchaseScope();
      allow write: if isPurchaseScope();
    }

    match /wsPaymentsDays/{day} {
      allow read:  if isPurchaseScope();
      allow write: if isPurchaseScope();
    }

    match /checksDays/{day} {
      allow read:  if isAnyAccountant();
      allow write: if isPurchaseScope();
    }

    /* ──────────────────────────────────────────────────────────
       V19.50 — invoices (V19.64: read scoped to relevant roles)
       ────────────────────────────────────────────────────────── */
    match /salesInvoicesDays/{day} {
      allow read:  if isSalesScope();
      allow write: if isSalesScope();
    }

    match /purchaseInvoicesDays/{day} {
      allow read:  if isPurchaseScope();
      allow write: if isPurchaseScope();
    }

    match /purchaseOrdersDays/{day} {
      allow read:  if isPurchaseScope();
      allow write: if isPurchaseScope();
    }

    /* ──────────────────────────────────────────────────────────
       V19.51 — sales-doc + tasks-doc splits
       (tasks/notes/sticky stay any-user — they're cross-team comms)
       ────────────────────────────────────────────────────────── */
    match /packagesDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }

    match /custDeliverySessionsDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }

    match /tasksDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isAuthed();
    }

    match /stickyNotesDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isAuthed();
    }

    match /inventoryAuditsDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }

    /* ──────────────────────────────────────────────────────────
       V19.52 — warehouse + treasury transfers (V19.64: scoped)
       ────────────────────────────────────────────────────────── */
    match /stockMovementsDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isPurchaseScope();
    }

    match /purchaseReceiptsDays/{day} {
      allow read:  if isPurchaseScope();
      allow write: if isPurchaseScope();
    }

    match /treasuryTransfersDays/{day} {
      allow read:  if isPurchaseScope();
      allow write: if isPurchaseScope();
    }

    match /salesAuditsDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }

    /* ──────────────────────────────────────────────────────────
       V19.53 — notifications + per-user state
       ────────────────────────────────────────────────────────── */
    match /notificationsDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isAuthed();
    }

    match /userNotifStates/{email} {
      allow read:  if isAnyUser();
      allow write: if isAuthed() && request.auth.token.email == email;
    }

    /* ──────────────────────────────────────────────────────────
       fixedAssets/{assetId}
       V19.64: read restricted to accountants (was any user)
       ────────────────────────────────────────────────────────── */
    match /fixedAssets/{assetId} {
      allow read:  if isAnyAccountant();
      allow write: if isManagerPlus();
    }

    /* ──────────────────────────────────────────────────────────
       backups/{backupId} + parts/{partName}
       V19.64: ADMIN ONLY (was manager+) — backups dump everything
       including HR salaries, customer balances, supplier credit.
       ────────────────────────────────────────────────────────── */
    match /backups/{backupId} {
      allow read, write: if isAdmin();

      match /parts/{partName} {
        allow read, write: if isAdmin();
      }
    }

    /* ──────────────────────────────────────────────────────────
       migrationLog/{logId}
       V19.64: write tightened to manager+ (was any authed)
       ────────────────────────────────────────────────────────── */
    match /migrationLog/{logId} {
      allow read:  if isManagerPlus();
      allow write: if isManagerPlus();
    }

    /* ──────────────────────────────────────────────────────────
       V21.9.19 — ROOT-CAUSE FIX: missing match clauses for
       collections introduced in V21.9.2+, V21.9.5+, V21.9.7+,
       V21.9.8+, and V21.9.18.

       Pre-V21.9.19 these collections fell through to the
       `match /{document=**} { allow read, write: if false; }`
       catch-all at the bottom of this file. Server endpoints
       (firebase-admin) bypass rules so writes succeeded, but
       CLIENT-side listeners and migrations were silently DENIED:

       Symptom 1: User syncs customers → server writes 1147 docs
         to shopifyCustomersDocs (admin SDK, bypasses rules).
         Client listener fails to subscribe → partitionedData
         stays empty → UI shows "no customers". User syncs
         again, sees toast "1147 customers", but list is still
         empty after refresh. They re-sync every time.

       Symptom 2: V21.9.18 migration writes orders to
         shopifyOrdersDays from the client (App.jsx auto-run).
         Rule denies → write fails → migration never completes
         → factory/config bloat stays.

       Fix: explicit match clauses for ALL Shopify, Bosta,
       AI Agent, sync-jobs, and recent-split collections.
       Read scoped to sales-or-admin (Shopify data is sales).
       Write scoped to admin/manager+ for safety.
       ────────────────────────────────────────────────────────── */

    /* V21.9.2 — Shopify per-doc collections (products + customers) */
    match /shopifyProductsDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }
    match /shopifyCustomersDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }

    /* V21.9.44 — Recurring treasury rules (per-id partitioned collection).
       Read = any authenticated user (so the TreasuryPg recurring tab loads).
       Write = purchase-scope (treasury actions, matches existing recurring tx
       creation permissions). MISSING this rule was the root cause of the
       "البرنامج لسه بيحمل بيانات" toast hang post-V21.9.44 migration:
       listener subscription would be denied → firstFires[recurringTreasury]
       stayed false → partitionedLoaded stuck at false → every upConfig refused. */
    match /recurringTreasuryDocs/{id} {
      allow read:  if isAnyUser();
      allow write: if isPurchaseScope();
    }

    /* V21.9.18 — Shopify pending orders, split daily */
    match /shopifyOrdersDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }

    /* V21.9.1 — historical orders archive (per yearmonth) */
    match /shopifyOrdersArchive/{month} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }

    /* V21.9 — Bosta deliveries archive */
    match /bostaDeliveriesArchive/{month} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }

    /* V21.9.5 — credit / debit notes (إشعارات الدائنة / المدينة) */
    match /salesCreditNotesDays/{day} {
      allow read:  if isSalesScope();
      allow write: if isSalesScope();
    }
    match /purchaseDebitNotesDays/{day} {
      allow read:  if isPurchaseScope();
      allow write: if isPurchaseScope();
    }

    /* V21.9.7 — Shopify return requests (طلبات الارتجاع) */
    match /shopifyReturnRequestsDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }

    /* V21.9.8 — WhatsApp campaigns (templates + per-customer run logs) */
    match /whatsappCampaignsDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }
    match /whatsappCampaignRunsDays/{day} {
      allow read:  if isAnyUser();
      allow write: if isSalesScope();
    }

    /* V21.9.4 — progress-tracker job docs.
       Each sync/pull operation creates a job doc and the CLIENT
       subscribes to its updates via onSnapshot. Without this rule
       the overlay would hang at "بدء العملية..." forever. */
    match /syncJobs/{jobId} {
      allow read:  if isAnyUser();
      allow write: if isManagerPlus();
    }

    /* V19.71+ — AI Agent collections.
       Phase A scaffold — even if not actively used yet, declaring
       the rules prevents future "why is the AI panel empty" surprises. */
    match /aiAgentConversations/{id} {
      allow read:  if isManagerPlus();
      allow write: if isManagerPlus();
    }
    match /aiAgentEscalations/{id} {
      allow read:  if isManagerPlus();
      allow write: if isManagerPlus();
    }
    match /aiAgentSalesNotifications/{id} {
      allow read:  if isSalesScope();
      allow write: if isManagerPlus();
    }
    match /aiAgentSuggestions/{id} {
      allow read:  if isManagerPlus();
      allow write: if isManagerPlus();
    }
    match /aiAgentAnalytics/{id} {
      allow read:  if isManagerPlus();
      allow write: if isManagerPlus();
    }

    /* ──────────────────────────────────────────────────────────
       Default deny — أي حاجة مش مذكورة فوق ممنوعة تماماً
       ────────────────────────────────────────────────────────── */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
