{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/ai-image/generate.js": { "maxDuration": 60 },
    "api/ai-image/analyze-prompt.js": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/cron/shopify-poll-orders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/shopify-push-inventory",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/shopify-cleanup-reservations",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/reconcile-financials",
      "schedule": "10 2 * * *"
    }
  ]
}
