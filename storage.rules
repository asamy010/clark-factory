rules_version = '2';

/* ═══════════════════════════════════════════════════════════════
   CLARK Factory — Firebase Storage Rules (V19.64)
   ═══════════════════════════════════════════════════════════════
   V19.64 SECURITY HARDENING:
   Pre-V19.64 used a single `match /{allPaths=**}` allowing any authed user
   to overwrite/delete any file. A `viewer` could replace customer-portal
   assets, delete invoices, swap logos, etc. There was also no MIME-type
   guard — a 99 MB executable masquerading as a PDF was allowed.

   New approach: path-prefixed scoping + content-type restrictions.

   Path layout (recommended convention used by upload helpers):
     invoices/**       — sales/purchase invoice attachments → sales/purchase scope writes
     orders/**         — order attachments (PDFs, images)   → manager+ writes
     templates/**      — campaign templates (V19.35)        → sales/manager writes
     campaigns/**      — campaign assets                    → sales/manager writes
     logos/**          — factory logos / branding           → admin only
     qr/**             — QR codes (server-generated mostly) → manager+ writes
     attachments/**    — generic attachments (orders/HR)    → manager+ writes
     temp/**           — temporary uploads (cleared periodically) → any authed write

   Rules of thumb:
   - Reads stay AUTH-required (no public access — public assets go on Vercel CDN).
   - Deletes restricted to manager+ across the board (viewer can't destroy data).
   - Size cap stays at 100MB (WhatsApp documents support up to 100MB).
   - MIME guards: images + PDF + common docs only. Executables blocked.

   Role lookup uses the same factory/config.users / usersList path as
   firestore.rules (Firebase doesn't share rule helpers across services,
   so it's duplicated below).
   ═══════════════════════════════════════════════════════════════ */

service firebase.storage {
  match /b/{bucket}/o {

    /* ── Auth + role helpers (mirror firestore.rules) ── */
    function isAuthed() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return request.auth != null
          && request.auth.uid == 'fJDTS57ndvVfPozGgwYybKJymuA3';
    }

    function getRole() {
      let cfg = firestore.get(/databases/(default)/documents/factory/config).data;
      let u = cfg.get('users', {}).get(request.auth.uid, '');
      return u is string
        ? (u == '' ? 'viewer' : u)
        : u.get('role', 'viewer');
    }

    function hasRole(roles) {
      return isAuthed() && (isBootstrapAdmin() || getRole() in roles);
    }

    /* V21.9.71 REVERT — restored hardcoded scopes (pre-V21.9.69 behavior).
       The V21.9.69 dynamic-scopes attempt (cross-service firestore.exists
       + firestore.get → roleScopes doc → .get(key, fallback)) BROKE all
       Storage uploads. Root cause: Storage rules CEL has limited support
       for the cross-service helpers + map.get(k, default) pattern that
       Firestore rules supports natively. The rule evaluated as an error
       → default-deny → 'storage/unauthorized' for everyone.
       Reverted per protocol §0.1 (push back on changes that need local
       testing the user can't perform). If admin needs to customize scopes
       for Storage (e.g., grant a custom role upload access), edit this
       file directly and redeploy. */
    function isAdmin()         { return hasRole(['admin']); }
    function isManagerPlus()   { return hasRole(['admin', 'manager']); }
    function isSalesScope()    { return hasRole(['admin','manager','sales_accountant']); }
    function isPurchaseScope() { return hasRole(['admin','manager','purchase_accountant','warehouse_keeper']); }

    /* ── Content-type + size guards ── */
    function isUnderSize() {
      return request.resource.size < 100 * 1024 * 1024;/* 100 MB */
    }

    function isAllowedMime() {
      /* Images, PDFs, and common office docs. Executables blocked. */
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
          || request.resource.contentType.matches('application/vnd\\.ms-.*')
          || request.resource.contentType.matches('text/(plain|csv)');
    }

    function isWriteSafe() {
      return isAuthed() && isUnderSize() && isAllowedMime();
    }

    /* ── Path-prefixed routes ── */

    /* invoices/** — sales + purchase scope */
    match /invoices/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && (isSalesScope() || isPurchaseScope());
      allow delete:         if isManagerPlus();
    }

    /* orders/** + seasons/** — manager+ writes */
    match /orders/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isManagerPlus();
      allow delete:         if isManagerPlus();
    }
    match /seasons/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isManagerPlus();
      allow delete:         if isManagerPlus();
    }

    /* templates/** + campaigns/** — sales + manager */
    match /templates/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isSalesScope();
      allow delete:         if isSalesScope();
    }
    match /campaigns/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isSalesScope();
      allow delete:         if isSalesScope();
    }

    /* logos/** — admin only (branding is sensitive) */
    match /logos/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isAdmin();
      allow delete:         if isAdmin();
    }

    /* qr/** — manager+ */
    match /qr/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isManagerPlus();
      allow delete:         if isManagerPlus();
    }

    /* attachments/** — manager+ (catches order/HR attachments) */
    match /attachments/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isManagerPlus();
      allow delete:         if isManagerPlus();
    }

    /* V21.9.11: shopify-products/** — Shopify product push images.
       Pre-V21.9.11 there was no path match for this prefix → fell through
       to the deny-all catch-all → all per-color image uploads from
       ShopifyPushModal failed at the Storage rule layer (in addition to
       the dataURL Blob bug). manager+ writes only since this is product
       data with public exposure on the storefront. */
    match /shopify-products/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isManagerPlus();
      allow delete:         if isManagerPlus();
    }

    /* V21.9.11: whatsapp-campaigns/** — campaign image uploads from the
       Composer modal. Same rationale — pre-V21.9.11 these were silently
       blocked by the catch-all. Sales scope (matches who can run
       campaigns). */
    match /whatsapp-campaigns/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && isSalesScope();
      allow delete:         if isSalesScope();
    }

    /* temp/** — any authed user (auto-cleanup expected) */
    match /temp/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe();
      allow delete:         if isAuthed();
    }

    /* V21.9.94 — documents/** (Documents Tree feature).
       User-managed document tree (contracts, PDFs, scanned papers, etc.).
       Each file lives under documents/{folderId}/{fileId}_{name}.{ext}.
       Soft-deletes go to documents/.trash/** (7-day retention).

       V21.9.96 REFACTOR: switched from inline role array to a union of
       existing tested helpers (isManagerPlus + isSalesScope + isPurchaseScope).
       The inline 6-role array deployed in V21.9.94 caused storage/unauthorized
       for the bootstrap admin — root cause unclear (CEL evaluation quirk?).
       Existing rules (templates, invoices, etc.) use the helper-union pattern
       and work reliably, so we mirror that approach here.

       Read: any authed user.
       Create/Update: managerPlus + sales/purchase scope (existing helpers).
       Delete: managerPlus only. */
    match /documents/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isWriteSafe() && (isManagerPlus() || isSalesScope() || isPurchaseScope());
      allow delete:         if isManagerPlus();
    }

    /* ── Default catch-all: deny ──
       V19.64: removed the permissive `match /{allPaths=**}` fallback that allowed
       any authed user to write anywhere. Files now MUST land in one of the
       known path prefixes above. */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
