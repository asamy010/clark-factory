rules_version = '2';

/*
   CLARK Factory - Firebase Storage Rules
   V21.9.99 - EMERGENCY DIAGNOSTIC MAX PERMISSIVE (syntax-clean)

   Root cause of V21.9.94 to V21.9.98 deploy failures: previous comment
   blocks contained the literal sequence "asterisk-asterisk-slash" inside
   path examples like "orders / double-star / attachments / double-star".
   The slash inside that pattern terminated the block comment early, so
   Firebase parsed the rest as code and threw a syntax error. Ahmed saw
   no rules deploy and storage/unauthorized for ALL paths.

   This file uses NO path literals with double-star inside comments.

   Strategy: bypass every helper. If THIS still fails -> root cause is
   App Check enforcement, bucket mismatch, or auth token issue.

   Once uploads are confirmed working, restore the secure ruleset from
   storage.rules.SECURE.bak (which has the same comment bug fixed
   inline before use).
*/

service firebase.storage {
  match /b/{bucket}/o {

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

  }
}
