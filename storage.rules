rules_version = '2';

/* ═══════════════════════════════════════════════════════════════
   CLARK Factory — Firebase Storage Rules (V18.70)

   Storage بيستخدم لـ:
   - مرفقات الفواتير (PDFs, صور)
   - صور الموديلات
   - logos + branding

   القاعدة الأساسية: أي user مسجل دخول يقدر يقرا/يكتب/يحذف.
   مفيش public access — كل الملفات تتطلب auth.

   ⚠️ ملاحظة: لو في حاجة public زي logo المصنع، خليه على CDN
   تاني (Vercel public folder) بدل Firebase Storage.
   ═══════════════════════════════════════════════════════════════ */

service firebase.storage {
  match /b/{bucket}/o {

    /* أي ملف داخل الـbucket — لازم تكون مسجل دخول */
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                && request.resource.size < 25 * 1024 * 1024;  /* حد أقصى 25MB */
    }
  }
}
