# CLARK — نموذج متغيّرات البيئة (V21.27.207)
# انسخه لـ .env محليًا لو محتاج. ملاحظة: .env متجاهَل في git (مفيش أسرار في الريبو).
#
# ملخّص: src/firebase.js بياخد الإعداد من المتغيّرات دي لو موجودة، وإلا الإنتاج
# الافتراضي. مفيش أي متغيّر مضبوط → سلوك الإنتاج زي ما هو بالظبط.

# ── 1) وضع الـ Emulator المحلي (npm run dev:emu بيضبطه تلقائيًا) ──
# خليه 1 عشان التطبيق يتوصل بالـ Firebase Emulator المحلي بدل الإنتاج.
VITE_USE_EMULATOR=0
# اختياري — لو غيّرت البورتات في firebase.json:
# VITE_EMULATOR_HOST=127.0.0.1
# VITE_EMULATOR_FIRESTORE_PORT=8080
# VITE_EMULATOR_AUTH_PORT=9099
# VITE_EMULATOR_STORAGE_PORT=9199

# ── 2) إعداد Firebase (للـ Staging على Vercel Preview فقط) ──
# سيبها فاضية للإنتاج (الكود بيستخدم إعداد الإنتاج الافتراضي).
# املاها في Vercel → Environment Variables → Preview فقط (مش Production!)
# ببيانات مشروع clark-staging. شوف docs/TESTING.md.
# VITE_FB_API_KEY=
# VITE_FB_AUTH_DOMAIN=
# VITE_FB_PROJECT_ID=
# VITE_FB_STORAGE_BUCKET=
# VITE_FB_SENDER_ID=
# VITE_FB_APP_ID=
